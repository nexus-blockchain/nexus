# ═══════════════════════════════════════════════════════
# GroupRobot 环境配置
# ═══════════════════════════════════════════════════════

# 平台模式: telegram | discord | both
PLATFORM=telegram

# Telegram Bot Token (必须)
BOT_TOKEN=123456:ABC-DEF

# Bot ID Hash (可选, 不设则从 BOT_TOKEN 自动派生)
# BOT_ID_HASH=0xaabbccdd...

# Webhook 配置
WEBHOOK_PORT=3000
WEBHOOK_URL=https://your-domain.com/webhook
WEBHOOK_SECRET=your-webhook-secret

# Discord 配置 (仅 discord/both 模式)
# DISCORD_BOT_TOKEN=your-discord-token
# DISCORD_APPLICATION_ID=your-app-id
# DISCORD_INTENTS=33281

# 链上 RPC
CHAIN_RPC=ws://127.0.0.1:9944
# CHAIN_SIGNER_SEED=0x...  # 可选, 不设则自动生成

# TEE 模式: auto | hardware | software
TEE_MODE=auto

# 数据目录
DATA_DIR=./data

# 性能
WEBHOOK_RATE_LIMIT=200
EXECUTE_RATE_LIMIT=100
CHAIN_LOG_BATCH_INTERVAL=6
CHAIN_LOG_BATCH_SIZE=50

# 监控
METRICS_ENABLED=true

# 日志级别
RUST_LOG=grouprobot=info
