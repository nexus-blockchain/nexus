{
  "name": "nexus-test-scripts",
  "version": "2.0.0",
  "description": "Nexus chain test scripts + E2E testing framework",
  "type": "module",
  "scripts": {
    "e2e": "tsx e2e/run-e2e.ts",
    "e2e:t1": "tsx e2e/run-e2e.ts --flow T1",
    "e2e:t2": "tsx e2e/run-e2e.ts --flow T2",
    "e2e:t3": "tsx e2e/run-e2e.ts --flow T3",
    "e2e:e1": "tsx e2e/run-e2e.ts --flow E1",
    "e2e:trading": "tsx e2e/run-e2e.ts --flow T1 T2 T3",
    "e2e:entity": "tsx e2e/run-e2e.ts --flow E1",
    "agent": "tsx e2e/nexus-test-agent.ts",
    "agent:cargo": "tsx e2e/nexus-test-agent.ts --mode cargo",
    "agent:e2e": "tsx e2e/nexus-test-agent.ts --mode e2e",
    "agent:coverage": "tsx e2e/nexus-test-agent.ts --mode coverage",
    "agent:entity": "tsx e2e/nexus-test-agent.ts --group entity",
    "agent:grouprobot": "tsx e2e/nexus-test-agent.ts --group grouprobot",
    "agent:p0": "tsx e2e/nexus-test-agent.ts --mode coverage --priority P0",
    "test:maker": "tsx test-maker.ts",
    "test:otc": "tsx test-otc.ts",
    "test:swap": "tsx test-swap.ts",
    "test:pricing": "tsx test-pricing.ts",
    "test:referral": "tsx test-referral.ts",
    "test:all": "tsx run-all-tests.ts"
  },
  "dependencies": {
    "@polkadot/api": "^12.0.0",
    "@polkadot/keyring": "^12.0.0",
    "@polkadot/util": "^12.0.0",
    "@polkadot/util-crypto": "^12.0.0"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "@types/node": "^20.0.0"
  }
}
