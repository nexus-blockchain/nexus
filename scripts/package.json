{
  "name": "nexus-test-scripts",
  "version": "3.0.0",
  "description": "Nexus runtime smoke and contract tests",
  "type": "module",
  "scripts": {
    "e2e": "tsx e2e/run.ts",
    "e2e:list": "tsx e2e/run.ts --list",
    "e2e:contracts": "tsx e2e/run.ts --suite runtime-contracts",
    "e2e:smoke": "tsx e2e/run.ts --suite chain-health entity-lifecycle nex-market-smoke",
    "e2e:typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@polkadot/api": "^12.0.0",
    "@polkadot/keyring": "^12.0.0",
    "@polkadot/util": "^12.0.0",
    "@polkadot/util-crypto": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
